# .editorconfig

# Define configurações de editor para manter consistência no código
# Suportado por VSCode, Vim, Emacs, Sublime e muitos outros

root = true

# Todos os arquivos
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Arquivos C
[*.{c,h}]
indent_style = space
indent_size = 4

# Arquivos CMake
[CMakeLists.txt]
indent_style = space
indent_size = 2

# Arquivos Markdown
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Arquivos de configuração
[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
